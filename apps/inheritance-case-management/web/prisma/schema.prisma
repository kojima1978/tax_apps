generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InheritanceCase {
  id                Int      @id @default(autoincrement())
  deceasedName      String
  dateOfDeath       DateTime @db.Date // YYYY-MM-DD（CHECK制約で検証済み）
  status            String   @default("未着手") // CHECK制約: 未着手/手続中/申告済/請求済/入金済
  handlingStatus    String   @default("対応中") // CHECK制約: 対応中/対応終了/未分割
  acceptanceStatus  String?  @default("未判定") // CHECK制約: 受託可/受託不可/未判定/保留
  taxAmount         Int?     @default(0)
  feeAmount         Int?     @default(0)
  fiscalYear        Int
  estimateAmount    Int?     @default(0)
  propertyValue     Int?     @default(0)
  referralFeeRate   Float?
  referralFeeAmount Int?
  landRosenkaCount  Int?     @default(0) // 土地数（路線価）
  landBairitsuCount Int?     @default(0) // 土地数（倍率）
  unlistedStockCount Int?    @default(0) // 非上場株式の数
  heirCount         Int?     @default(0) // 相続人の数
  summary           String?  @db.VarChar(10) // 特記事項（短い概要、最大10文字）
  memo              String?  @db.Text        // メモ（フリーテキスト）

  // Normalized FK references
  assigneeId            Int?
  assignee              Assignee?      @relation("CaseAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  internalReferrerId    Int?
  internalReferrer      Assignee?      @relation("CaseInternalReferrer", fields: [internalReferrerId], references: [id], onDelete: SetNull)
  referrerId            Int?
  referrer              Referrer?      @relation(fields: [referrerId], references: [id], onDelete: SetNull)

  // Normalized child tables
  contacts          CaseContact[]
  progress          CaseProgress[]
  expenses          CaseExpense[]

  // Audit fields
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Indexes for common queries
  @@index([status])
  @@index([handlingStatus])
  @@index([fiscalYear])
  @@index([acceptanceStatus])
  @@index([createdAt])
  @@index([assigneeId])
  @@index([internalReferrerId])
  @@index([referrerId])
}

model Department {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  sortOrder  Int        @default(0)
  active     Boolean    @default(true)
  assignees  Assignee[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
}

model Assignee {
  id           Int          @id @default(autoincrement())
  name         String
  employeeId   String?
  departmentId Int?
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  active       Boolean      @default(true)
  assignedCases          InheritanceCase[] @relation("CaseAssignee")
  internalReferredCases  InheritanceCase[] @relation("CaseInternalReferrer")

  // Audit fields
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([name])
  @@index([departmentId])
}

model Company {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  active    Boolean         @default(true)
  referrers Referrer[]
  branches  CompanyBranch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model CompanyBranch {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name      String
  active    Boolean    @default(true)
  referrers Referrer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([active])
  @@index([companyId])
}

model Referrer {
  id         Int            @id @default(autoincrement())
  companyId  Int
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branchId   Int?
  branch     CompanyBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  active     Boolean        @default(true)
  cases      InheritanceCase[]

  // Audit fields
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ユニーク制約はCOALESCE付き機能インデックスで実装（migration SQL参照）
  // NULL同士を同一視するため @@unique ではなく raw SQL を使用
  @@index([active])
  @@index([companyId])
  @@index([branchId])
}

model CaseContact {
  id        Int             @id @default(autoincrement())
  caseId    Int
  case      InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sortOrder Int             @default(0)
  name      String
  phone     String          @default("")
  email     String          @default("")

  @@index([caseId])
}

model CaseProgress {
  id        Int             @id @default(autoincrement())
  caseId    Int
  case      InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stepId    String
  name      String
  sortOrder Int             @default(0)
  date      DateTime?       @db.Date // YYYY-MM-DD
  memo      String?
  isDynamic Boolean         @default(false)

  @@index([caseId])
  @@index([caseId, sortOrder])
}

model CaseExpense {
  id          Int             @id @default(autoincrement())
  caseId      Int
  case        InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sortOrder   Int             @default(0)
  date        DateTime        @db.Date // YYYY-MM-DD
  description String          // 内容（自由入力）
  amount      Int             // 金額（円）
  memo        String?         // 備考

  @@index([caseId])
  @@index([caseId, sortOrder])
}
