generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InheritanceCase {
  id                Int      @id @default(autoincrement())
  deceasedName      String
  deceasedNameKana            String   @default("")
  deceasedNameKanaNormalized  String   @default("")
  dateOfDeath       DateTime @db.Date // YYYY-MM-DD（CHECK制約で検証済み）
  status            String   @default("見積前") // CHECK制約: 見積前/見積中/見送り/受託/手続中/最終確認/申告済/請求済/入金済
  isUndivided       Boolean  @default(false)  // 遺産未分割フラグ（申告済以降で意味を持つ）
  taxAmount         Int?     @default(0)
  feeAmount         Int?     @default(0)
  fiscalYear        Int
  estimateAmount    Int?     @default(0)
  propertyValue     Int?     @default(0)
  referralFeeRate   Float?
  referralFeeAmount Int      @default(0)
  estimateReferralFeeAmount Int @default(0)
  isReferralFeeManual Boolean @default(false)
  isEstimateReferralFeeManual Boolean @default(false)
  landRosenkaCount  Int?     @default(0) // 土地数（路線価）
  landBairitsuCount Int?     @default(0) // 土地数（倍率）
  unlistedStockCount Int?    @default(0) // 非上場株式の数
  feeCalculationHeirCount Int? @default(0) // 報酬計算に使用する相続人数（紐付け人数とは別）
  discountAmount    Int?     @default(0) // 値引額（円）
  feeCalcSnapshot   Json?    // 報酬計算時のパラメータ・料率・内訳スナップショット
  summary           String?  @db.VarChar(10) // 特記事項��短い概要、最大10���字）
  memo              String?  @db.Text        // メモ（フリーテキスト）
  caseAddedDate     DateTime? @db.Date       // 受託日（ステータス連動: 受託で自動）
  caseCompletedDate DateTime? @db.Date       // 申告日（ステータス連動: 申告済で自動）
  billedDate        DateTime? @db.Date       // 請求日（ステータス連動: 請求済で自動）
  paidDate          DateTime? @db.Date       // 入金日（ステータス連動: 入金済で自動）

  // Normalized FK references
  assigneeId            Int?
  assignee              Assignee?      @relation("CaseAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  internalReferrerId    Int?
  internalReferrer      Assignee?      @relation("CaseInternalReferrer", fields: [internalReferrerId], references: [id], onDelete: SetNull)
  referrerId            Int?
  referrer              Referrer?      @relation(fields: [referrerId], references: [id], onDelete: SetNull)

  // Normalized child tables
  heirs             CaseHeir[]
  relatedParties    CaseRelatedParty[]
  progress          CaseProgress[]
  expenses          CaseExpense[]
  specialAdditions  CaseSpecialAddition[]

  // Audit fields
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Indexes for common queries
  @@index([status])
  @@index([fiscalYear])
  @@index([isUndivided])
  @@index([createdAt])
  @@index([caseAddedDate])
  @@index([caseCompletedDate])
  @@index([billedDate])
  @@index([paidDate])
  @@index([assigneeId])
  @@index([internalReferrerId])
  @@index([referrerId])
  @@index([deceasedNameKana])
  @@index([deceasedNameKanaNormalized])
  @@index([fiscalYear, status, dateOfDeath], map: "InheritanceCase_list_status_idx")
  @@index([fiscalYear, assigneeId, dateOfDeath], map: "InheritanceCase_list_assignee_idx")
  @@index([fiscalYear, internalReferrerId, dateOfDeath], map: "InheritanceCase_list_internal_referrer_idx")
}

model Department {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  sortOrder  Int        @default(0)
  active     Boolean    @default(true)
  assignees  Assignee[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
}

model Assignee {
  id           Int          @id @default(autoincrement())
  name         String
  employeeId   String?
  departmentId Int?
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  active       Boolean      @default(true)
  assignedCases          InheritanceCase[] @relation("CaseAssignee")
  internalReferredCases  InheritanceCase[] @relation("CaseInternalReferrer")

  // Audit fields
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@index([name])
  @@index([departmentId])
}

model Company {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  active    Boolean         @default(true)
  referrers Referrer[]
  branches  CompanyBranch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model CompanyBranch {
  id        Int        @id @default(autoincrement())
  companyId Int
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name      String
  active    Boolean    @default(true)
  referrers Referrer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([active])
  @@index([companyId])
}

model Referrer {
  id         Int            @id @default(autoincrement())
  companyId  Int
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branchId   Int?
  branch     CompanyBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  active     Boolean        @default(true)
  cases      InheritanceCase[]

  // Audit fields
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ユニーク制約はCOALESCE付き機能インデックスで実装（migration SQL参照）
  // NULL同士を同一視するため @@unique ではなく raw SQL を使用
  @@index([active])
  @@index([companyId])
  @@index([branchId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  entity    String   // InheritanceCase, Assignee, etc.
  entityId  Int
  action    String   // CREATE, UPDATE, DELETE
  changes   Json?    // [{ field, old, new }]
  changedBy String?
  changedAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([changedAt])
}

model HeirPerson {
  id                  Int           @id @default(autoincrement())
  name                String
  nameKana            String        @default("")
  nameKanaNormalized  String        @default("")
  dateOfBirth         DateTime?     @db.Date  // 生年月日（YYYY-MM-DD、未入力可）
  phone               String        @default("")
  postalCode          String        @default("")
  address             String        @default("")
  addressFromPostalCode String      @default("")
  addressManual       String        @default("")
  memo                String        @default("")
  active              Boolean       @default(true)
  caseLinks           CaseHeir[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([name])
  @@index([nameKana])
  @@index([nameKanaNormalized])
  @@index([active])
}

model RelatedPartyPerson {
  id                  Int                   @id @default(autoincrement())
  name                String
  nameKana            String                @default("")
  nameKanaNormalized  String                @default("")
  profession          String                @default("")  // 業種: 税理士/司法書士/土地家屋調査士など、自由入力可
  phone               String                @default("")
  postalCode          String                @default("")
  address             String                @default("")
  addressFromPostalCode String              @default("")
  addressManual       String                @default("")
  memo                String                @default("")
  active              Boolean               @default(true)
  caseLinks           CaseRelatedParty[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([name])
  @@index([nameKana])
  @@index([nameKanaNormalized])
  @@index([profession])
  @@index([active])
}

model CaseHeir {
  id                    Int             @id @default(autoincrement())
  caseId                Int
  case                  InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personId              Int
  person                HeirPerson      @relation(fields: [personId], references: [id], onDelete: Restrict)
  relationship          String          @default("")  // 続柄: 配偶者/長男など、自由入力可
  relationshipSortOrder Int             @default(999) // 続柄ソート用（HEIR_RELATIONSHIPS の sort 値）
  sortOrder             Int             @default(0)   // 手動上書き用
  memo                  String          @default("")

  @@unique([caseId, personId])
  @@index([caseId])
  @@index([personId])
}

model CaseRelatedParty {
  id        Int                @id @default(autoincrement())
  caseId    Int
  case      InheritanceCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personId  Int
  person    RelatedPartyPerson @relation(fields: [personId], references: [id], onDelete: Restrict)
  sortOrder Int                @default(0)
  memo      String             @default("")

  @@unique([caseId, personId])
  @@index([caseId])
  @@index([personId])
}

model CaseProgress {
  id        Int             @id @default(autoincrement())
  caseId    Int
  case      InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stepId    String
  name      String
  sortOrder Int             @default(0)
  date      DateTime?       @db.Date // YYYY-MM-DD
  memo      String?
  isDynamic Boolean         @default(false)

  @@index([caseId])
  @@index([caseId, sortOrder])
}

model CaseExpense {
  id          Int             @id @default(autoincrement())
  caseId      Int
  case        InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sortOrder   Int             @default(0)
  date        DateTime        @db.Date // YYYY-MM-DD
  description String          // 内容（自由入力）
  amount      Int             // 金額（円）
  memo        String?         // 備考

  @@index([caseId])
  @@index([caseId, sortOrder])
}

model CaseSpecialAddition {
  id          Int             @id @default(autoincrement())
  caseId      Int
  case        InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sortOrder   Int             @default(0)
  description String          @db.VarChar(100)
  amount      Int             @default(0)

  @@index([caseId])
  @@index([caseId, sortOrder])
}
