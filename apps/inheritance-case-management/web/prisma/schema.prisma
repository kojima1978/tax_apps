generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InheritanceCase {
  id                Int      @id @default(autoincrement())
  deceasedName      String
  dateOfDeath       String
  status            String   @default("未着手") // "未着手" | "進行中" | "完了（税務申告済）" | "入金済" | "対応終了"
  acceptanceStatus  String?  @default("未判定") // "受託可" | "受託不可" | "未判定" | "保留"
  taxAmount         Int?     @default(0)
  feeAmount         Int?     @default(0)
  fiscalYear        Int
  estimateAmount    Int?     @default(0)
  propertyValue     Int?     @default(0)
  referralFeeRate   Float?
  referralFeeAmount Int?
  summary           String?  @db.VarChar(10) // 特記事項（短い概要、最大10文字）
  memo              String?  @db.Text        // メモ（フリーテキスト）

  // Normalized FK references
  assigneeId        Int?
  assignee          Assignee?      @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  referrerId        Int?
  referrer          Referrer?      @relation(fields: [referrerId], references: [id], onDelete: SetNull)

  // Normalized child tables
  contacts          CaseContact[]
  progress          CaseProgress[]

  // Audit fields
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Indexes for common queries
  @@index([status])
  @@index([fiscalYear])
  @@index([acceptanceStatus])
  @@index([createdAt])
  @@index([assigneeId])
  @@index([referrerId])
}

model Assignee {
  id         Int      @id @default(autoincrement())
  name       String
  employeeId String?
  department String?
  active     Boolean  @default(true)
  cases      InheritanceCase[]

  // Audit fields
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
  @@index([name])
}

model Referrer {
  id         Int      @id @default(autoincrement())
  company    String
  name       String
  department String?
  active     Boolean  @default(true)
  cases      InheritanceCase[]

  // Audit fields
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
  @@index([company])
}

model CaseContact {
  id        Int             @id @default(autoincrement())
  caseId    Int
  case      InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sortOrder Int             @default(0)
  name      String
  phone     String          @default("")
  email     String          @default("")

  @@index([caseId])
}

model CaseProgress {
  id        Int             @id @default(autoincrement())
  caseId    Int
  case      InheritanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stepId    String
  name      String
  sortOrder Int             @default(0)
  date      String?
  memo      String?
  isDynamic Boolean         @default(false)

  @@index([caseId])
  @@index([caseId, sortOrder])
}
